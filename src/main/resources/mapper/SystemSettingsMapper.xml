<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.group3.xd_lms.mapper.SystemSettingsMapper">

    <resultMap id="BaseResultMap" type="com.group3.xd_lms.entity.SystemSetting">
        <id column="setting_key" property="settingKey"/>
        <result column="setting_value" property="settingValue"/>
        <result column="description" property="description"/>
    </resultMap>

    <select id="selectAllSettings" resultMap="BaseResultMap">
        SELECT * FROM system_settings
    </select>

    <select id="selectValueByKey" resultType="java.lang.String">
        SELECT setting_value FROM system_settings WHERE setting_key = #{key}
    </select>

    <update id="updateSetting">
        UPDATE system_settings
        SET setting_value = #{value}
        WHERE setting_key = #{key}
    </update>

</mapper>